{
  "manifest_version": 3,
  "name": "Smart Seller Profit Calculator",
  "version": "1.0.0",
  "description": "Calculate profit, margin & break-even for every order. Includes target profit mode, saved products & Bangladesh courier presets.",
  "author": "Shajid Hassan",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Seller Profit Calculator",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"]
}
